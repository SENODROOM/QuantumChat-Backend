PORT=5000
# Either set a full connection string...
MONGODB_URI=mongodb://127.0.0.1:27017/QuantumChat

# Commented out to avoid conflicts with local DB
# MONGODB_USER=
# MONGODB_PASSWORD=
# MONGODB_CLUSTER=
# MONGODB_DB=QuantumChat

JWT_SECRET=change_this_to_a_long_random_secret
QUANTUM_AI_SERVICE_SECRET=change_this_to_a_second_long_random_shared_secret
JWT_EXPIRES_IN=7d
# Comma-separated list of allowed frontend origins, e.g.
# CLIENT_URL=http://localhost:5173,http://localhost:5175,https://your-frontend.vercel.app
# 5173 = QuantumChat frontend, 5175 = QuantumAI frontend (local Vite)
CLIENT_URL=http://localhost:5173,http://localhost:5175
FRONTEND_URL=http://localhost:5173

EXPOSE_EMAIL_LINKS=1

UPLOAD_DIR=uploads
